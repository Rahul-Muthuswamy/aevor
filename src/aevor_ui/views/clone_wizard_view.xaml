<UserControl x:Class="Aevor.UI.Views.CloneWizardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Step Circle: base -->
        <Style x:Key="StepCircleStyle" TargetType="Border">
            <Setter Property="Width"        Value="32" />
            <Setter Property="Height"       Value="32" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Background"   Value="#E5E7EB" />
        </Style>

        <!-- Option row in configure step -->
        <Style x:Key="OptionRowStyle" TargetType="Border">
            <Setter Property="Padding"          Value="20,14" />
            <Setter Property="BorderBrush"      Value="#F3F4F6" />
            <Setter Property="BorderThickness"  Value="0,0,0,1" />
            <Setter Property="Background"       Value="Transparent" />
        </Style>
    </UserControl.Resources>

    <!-- ═══════════════════════════════════════════════════════════════
         Root Grid: 4 rows — Header | Stepper | Content | Footer
         ═══════════════════════════════════════════════════════════════ -->
    <Grid Background="{DynamicResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- Header   -->
            <RowDefinition Height="Auto" />   <!-- Stepper  -->
            <RowDefinition Height="*"    />   <!-- Content  -->
            <RowDefinition Height="Auto" />   <!-- Footer   -->
        </Grid.RowDefinitions>

        <!-- ════════════════════════════════════════════════════════════
             Row 1 — Page Header
             ════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Padding="32,28,32,0"
                Background="{DynamicResource BackgroundBrush}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="{StaticResource AevorIcon}" Height="36" Width="36" RenderOptions.BitmapScalingMode="HighQuality" Margin="0,0,12,0"/>
                    <TextBlock Text="Clone Profile" Style="{StaticResource H1TextBlockStyle}" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="Create an identical copy of an existing profile"
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{DynamicResource MutedBrush}"
                           Margin="0,6,0,0" />
            </StackPanel>
        </Border>

        <!-- ════════════════════════════════════════════════════════════
             Row 2 — Step Indicator
             ════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Padding="32,24,32,20"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <ItemsControl ItemsSource="{Binding Steps}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="1" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Each step: circle + label, stacked vertically, centered -->
                        <StackPanel HorizontalAlignment="Center">
                            <!-- Circle -->
                            <Border Width="32" Height="32" CornerRadius="16"
                                    HorizontalAlignment="Center">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#E5E7EB" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}"    Value="True">
                                                <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="13" FontWeight="Bold"
                                           FontFamily="{StaticResource DefaultFontFamily}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text"       Value="{Binding StepNumber}" />
                                            <Setter Property="Foreground" Value="{DynamicResource MutedBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}"    Value="True">
                                                    <Setter Property="Foreground" Value="White" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                    <Setter Property="Text"       Value="✓" />
                                                    <Setter Property="Foreground" Value="White" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                            <!-- Label -->
                            <TextBlock Text="{Binding Title}"
                                       HorizontalAlignment="Center"
                                       Margin="0,6,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionTextBlockStyle}">
                                        <Setter Property="Foreground" Value="{DynamicResource MutedBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}"    Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>


            </ItemsControl>
        </Border>

        <!-- ════════════════════════════════════════════════════════════
             Row 3 — Step Content Area (with Banner + Scrollable Content)
             ════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Error Banner -->
            <Border Grid.Row="0"
                    Background="#FEF2F2"
                    BorderBrush="{DynamicResource DangerBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="32,12">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding WizardErrorMessage}" Value="">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding WizardErrorMessage}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="⚠️" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding WizardErrorMessage}"
                               Foreground="#991B1B"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="32">

                <!-- ──────────────────────────────────────────────────
                     STEP 1 — Source Profile Selection
                     ────────────────────────────────────────────────── -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStepIndex}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock Text="Select Source Profile"
                               Style="{StaticResource H3TextBlockStyle}" />
                    <TextBlock Text="Choose the Brave profile you want to clone"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Foreground="{DynamicResource MutedBrush}"
                               Margin="0,4,0,0" />

                    <ListBox ItemsSource="{Binding AvailableProfiles}"
                             SelectedItem="{Binding SelectedSourceProfile}"
                             BorderThickness="0"
                             Background="Transparent"
                             Margin="0,24,0,0">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,8" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="{StaticResource CornerRadiusMD}"
                                        Padding="16,14"
                                        Cursor="Hand">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderThickness" Value="1" />
                                            <Setter Property="Background"      Value="{DynamicResource BackgroundBrush}" />
                                            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                    <Setter Property="BorderBrush"    Value="{DynamicResource PrimaryBrush}" />
                                                    <Setter Property="BorderThickness" Value="2" />
                                                    <Setter Property="Background"      Value="#FAF5FF" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*"    />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <!-- Avatar -->
                                        <Border Grid.Column="0"
                                                Width="36" Height="36" CornerRadius="18"
                                                Background="#F7E5FC" Margin="0,0,12,0">
                                            <TextBlock Text="{Binding [0]}"
                                                       Foreground="{DynamicResource PrimaryBrush}"
                                                       FontWeight="Bold" FontSize="14"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <!-- Name -->
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding}"
                                                   Style="{StaticResource BodyTextBlockStyle}"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                        <!-- Radio indicator -->
                                        <Ellipse Grid.Column="2"
                                                 Width="18" Height="18"
                                                 StrokeThickness="2"
                                                 VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Stroke" Value="{DynamicResource BorderBrush}" />
                                                    <Setter Property="Fill"   Value="Transparent" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                            <Setter Property="Stroke" Value="{DynamicResource PrimaryBrush}" />
                                                            <Setter Property="Fill"   Value="{DynamicResource PrimaryBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>

                <!-- ──────────────────────────────────────────────────
                     STEP 2 — Security Review
                     ────────────────────────────────────────────────── -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStepIndex}" Value="1">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock Text="Security Review"
                               Style="{StaticResource H3TextBlockStyle}" />
                    <TextBlock Text="The following data has been scanned for the selected profile"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Foreground="{DynamicResource MutedBrush}"
                               Margin="0,4,0,0" />

                    <!-- Summary Banner -->
                    <Border Margin="0,24,0,0"
                            CornerRadius="{StaticResource CornerRadiusMD}"
                            Padding="16"
                            Background="{Binding SecurityBannerBackground}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="✓" />
                                        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasWarnings}" Value="True">
                                                <Setter Property="Text"       Value="⚠" />
                                                <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{Binding SecuritySummary}"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!-- Findings List -->
                    <Border Margin="0,16,0,0"
                            Style="{StaticResource CardStyle}"
                            Padding="0">
                        <ItemsControl ItemsSource="{Binding SecurityFindings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="20,14"
                                            BorderBrush="#F3F4F6"
                                            BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*"    />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <!-- Dot -->
                                            <Ellipse Grid.Column="0"
                                                     Width="8" Height="8"
                                                     Fill="{Binding SeverityColor}"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,14,0" />
                                            <!-- Text -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}"
                                                           Style="{StaticResource BodyTextBlockStyle}"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Detail}"
                                                           Style="{StaticResource BodySmallTextBlockStyle}"
                                                           Foreground="{DynamicResource MutedBrush}"
                                                           Margin="0,3,0,0"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                            <!-- Badge -->
                                            <Border Grid.Column="2"
                                                    Background="{Binding SeverityBadgeBackground}"
                                                    CornerRadius="10"
                                                    Padding="8,3"
                                                    VerticalAlignment="Center"
                                                    Margin="12,0,0,0">
                                                <TextBlock Text="{Binding SeverityLabel}"
                                                           Style="{StaticResource CaptionTextBlockStyle}"
                                                           Foreground="{Binding SeverityColor}"
                                                           FontWeight="Bold" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </StackPanel>

                <!-- ──────────────────────────────────────────────────
                     STEP 3 — Backup
                     ────────────────────────────────────────────────── -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStepIndex}" Value="2">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock Text="Create Backup"
                               Style="{StaticResource H3TextBlockStyle}" />
                    <TextBlock Text="Protect your original profile before cloning"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Foreground="{DynamicResource MutedBrush}"
                               Margin="0,4,0,0" />

                    <!-- Backup Toggle Card -->
                    <Border Margin="0,24,0,0"
                            Style="{StaticResource CardStyle}"
                            Padding="20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"    />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Backup Before Clone"
                                           Style="{StaticResource BodyTextBlockStyle}"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="Recommended — creates a restore point if anything goes wrong"
                                           Style="{StaticResource BodySmallTextBlockStyle}"
                                           Foreground="{DynamicResource MutedBrush}"
                                           Margin="0,4,0,0"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <CheckBox Grid.Column="1"
                                      IsChecked="{Binding CreateBackupBeforeClone}"
                                      VerticalAlignment="Center"
                                      Margin="16,0,0,0" />
                        </Grid>
                    </Border>

                    <!-- Backup Location (visible when enabled) -->
                    <StackPanel Margin="0,16,0,0"
                                Visibility="{Binding CreateBackupBeforeClone, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="BACKUP LOCATION"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{DynamicResource MutedBrush}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6" />
                        <TextBox Text="{Binding BackupLocation, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <!-- Backup Progress / Status -->
                    <StackPanel Margin="0,20,0,0"
                                Visibility="{Binding IsBackingUp, Converter={StaticResource BoolToVis}}">
                        <ProgressBar IsIndeterminate="True" Height="6" Margin="0,0,0,8" Foreground="{DynamicResource PrimaryBrush}" />
                        <TextBlock Text="{Binding BackupStatusMessage}"
                                   Style="{StaticResource BodySmallTextBlockStyle}"
                                   Foreground="{DynamicResource PrimaryBrush}"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <!-- ──────────────────────────────────────────────────
                     STEP 4 — Clone Configuration
                     ────────────────────────────────────────────────── -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStepIndex}" Value="3">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock Text="Configure Clone"
                               Style="{StaticResource H3TextBlockStyle}" />
                    <TextBlock Text="Choose what to include in the cloned profile"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Foreground="{DynamicResource MutedBrush}"
                               Margin="0,4,0,0" />

                    <!-- New Profile Name -->
                    <StackPanel Margin="0,24,0,0">
                        <TextBlock Text="NEW PROFILE NAME"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource MutedBrush}"
                                   Margin="0,0,0,6" />
                        <Grid>
                            <TextBox Text="{Binding NewProfileName, UpdateSourceTrigger=PropertyChanged}"
                                     x:Name="ProfileNameBox" />
                            <TextBlock Text="e.g. Work — Copy"
                                       Foreground="{DynamicResource MutedBrush}"
                                       FontSize="13"
                                       FontFamily="{StaticResource DefaultFontFamily}"
                                       Padding="14,10,0,0"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding NewProfileName}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </StackPanel>

                    <!-- Options -->
                    <Border Margin="0,20,0,0"
                            Style="{StaticResource CardStyle}"
                            Padding="0">
                        <StackPanel>
                            <!-- Extensions -->
                            <Border Style="{StaticResource OptionRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"    />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Extensions"
                                                   Style="{StaticResource BodyTextBlockStyle}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="Copy all installed extensions"
                                                   Style="{StaticResource BodySmallTextBlockStyle}"
                                                   Foreground="{DynamicResource MutedBrush}"
                                                   Margin="0,3,0,0" />
                                    </StackPanel>
                                    <CheckBox Grid.Column="1"
                                              IsChecked="{Binding CopyExtensions}"
                                              VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                            <!-- Bookmarks -->
                            <Border Style="{StaticResource OptionRowStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"    />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Bookmarks"
                                                   Style="{StaticResource BodyTextBlockStyle}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="Copy bookmark folders and entries"
                                                   Style="{StaticResource BodySmallTextBlockStyle}"
                                                   Foreground="{DynamicResource MutedBrush}"
                                                   Margin="0,3,0,0" />
                                    </StackPanel>
                                    <CheckBox Grid.Column="1"
                                              IsChecked="{Binding CopyBookmarks}"
                                              VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                            <!-- Themes (no bottom border) -->
                            <Border Padding="20,14" Background="Transparent">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"    />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Themes"
                                                   Style="{StaticResource BodyTextBlockStyle}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="Copy theme and appearance settings"
                                                   Style="{StaticResource BodySmallTextBlockStyle}"
                                                   Foreground="{DynamicResource MutedBrush}"
                                                   Margin="0,3,0,0" />
                                    </StackPanel>
                                    <CheckBox Grid.Column="1"
                                              IsChecked="{Binding CopyThemes}"
                                              VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ──────────────────────────────────────────────────
                     STEP 5 — Execute
                     ────────────────────────────────────────────────── -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStepIndex}" Value="4">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock Text="Cloning Profile"
                               Style="{StaticResource H3TextBlockStyle}" />
                    <TextBlock Text="Please wait while Aevor creates your cloned profile"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Foreground="{DynamicResource MutedBrush}"
                               Margin="0,4,0,0" />

                    <!-- Progress Area -->
                    <StackPanel Margin="0,40,0,0" HorizontalAlignment="Center">

                        <!-- ProgressBar -->
                        <ProgressBar Value="{Binding CloneProgress}"
                                     Minimum="0" Maximum="100"
                                     Height="10"
                                     Width="480"
                                     Foreground="{DynamicResource PrimaryBrush}"
                                     Background="#E5E7EB" />

                        <!-- Percentage -->
                        <TextBlock Text="{Binding CloneProgressText}"
                                   Style="{StaticResource H2TextBlockStyle}"
                                   HorizontalAlignment="Center"
                                   Margin="0,20,0,0" />

                        <!-- Status Message -->
                        <TextBlock Text="{Binding CloneStatusMessage}"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   Foreground="{DynamicResource MutedBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0" />

                        <!-- Start Button (only before cloning starts) -->
                        <Button Content="Start Clone"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding StartCloneCommand}"
                                HorizontalAlignment="Center"
                                Margin="0,32,0,0"
                                Visibility="{Binding ShowStartButton, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>
                </StackPanel>

                <!-- ──────────────────────────────────────────────────
                     STEP 6 — Completion
                     ────────────────────────────────────────────────── -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStepIndex}" Value="5">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <StackPanel HorizontalAlignment="Center" Margin="0,32,0,0">
                        <!-- Success Circle -->
                        <Border Width="80" Height="80" CornerRadius="40"
                                Background="#D1FAE5"
                                HorizontalAlignment="Center">
                            <TextBlock Text="✓"
                                       Style="{StaticResource H1TextBlockStyle}"
                                       Foreground="{DynamicResource SuccessBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>

                        <!-- Title -->
                        <TextBlock Text="Clone Complete"
                                   Style="{StaticResource H2TextBlockStyle}"
                                   HorizontalAlignment="Center"
                                   Margin="0,24,0,0" />

                        <!-- Message -->
                        <TextBlock Text="{Binding CompletionMessage}"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   Foreground="{DynamicResource MutedBrush}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Margin="0,8,0,0"
                                   MaxWidth="420"
                                   TextWrapping="Wrap" />

                        <!-- Done Button -->
                        <Button Content="Done"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding FinishCommand}"
                                HorizontalAlignment="Center"
                                Margin="0,32,0,0"
                                Width="160" />
                    </StackPanel>
                </StackPanel>

            </Grid>
        </ScrollViewer>
        </Grid>

        <!-- ════════════════════════════════════════════════════════════
             Row 4 — Footer Navigation (always visible, never scrolls)
             ════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="3"
                Padding="32,16"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Background="{DynamicResource BackgroundBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*"    />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Left: Cancel -->
                <Button Grid.Column="0"
                        Content="Cancel"
                        Style="{StaticResource GhostButton}"
                        Command="{Binding CancelCommand}" />

                <!-- Right: Back + Next/Finish -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">

                    <!-- Back (hidden on step 1 and step 6) -->
                    <Button Content="← Back"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding PreviousStepCommand}"
                            Margin="0,0,8,0"
                            Visibility="{Binding CanGoBack, Converter={StaticResource BoolToVis}}" />

                    <!-- Next (hidden on last step) -->
                    <Button Content="Next →"
                            Command="{Binding NextStepCommand}"
                            Width="100">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLastStep}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Finish (only on last step) -->
                    <Button Content="Finish"
                            Command="{Binding FinishCommand}"
                            Width="100">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLastStep}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</UserControl>


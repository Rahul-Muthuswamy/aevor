<UserControl x:Class="Aevor.UI.Views.BackupsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900">

    <UserControl.Resources>

        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*"    />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="32,32,32,24" Background="White">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"    />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="{StaticResource AevorIcon}" Height="36" Width="36" RenderOptions.BitmapScalingMode="HighQuality" Margin="0,0,12,0"/>
                        <TextBlock Text="Backups" Style="{StaticResource H1TextBlockStyle}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Profile snapshots you can restore at any time"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Foreground="{DynamicResource MutedBrush}"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">

                    <Border Width="240"
                            BorderBrush="{DynamicResource ControlBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CornerRadiusMD}"
                            Background="{DynamicResource SurfaceBrush}">
                        <Grid>
                            <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Padding="10,8"
                                     FontSize="13"
                                     FontFamily="{StaticResource DefaultFontFamily}"
                                     Foreground="{DynamicResource TextBrush}"
                                     VerticalContentAlignment="Center"
                                     x:Name="SearchBox" />

                            <TextBlock Text="Search backups..."
                                       Foreground="{DynamicResource MutedBrush}"
                                       FontSize="13"
                                       FontFamily="{StaticResource DefaultFontFamily}"
                                       Padding="12,9,0,0"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SearchQuery}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SearchQuery}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <Button Content="Delete Selected"
                            Style="{StaticResource DangerButton}"
                            Command="{Binding DeleteSelectedCommand}"
                            Visibility="{Binding HasSelectedBackups, Converter={StaticResource BoolToVis}}"
                            Margin="12,0,0,0" />

                    <Button Content="Create Backup"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding CreateBackupCommand}"
                            Margin="12,0,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Border Padding="32,0,32,32" Background="White">
                <StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,24">

                    <Border Style="{StaticResource CardStyle}" Padding="16,20" Margin="0,0,12,0" Background="{DynamicResource SurfaceBrush}">
                        <StackPanel Width="120">
                            <TextBlock Text="{Binding TotalBackups}" Style="{StaticResource H2TextBlockStyle}" />
                            <TextBlock Text="Total Backups" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource MutedBrush}" Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Padding="16,20" Margin="0,0,12,0" Background="{DynamicResource SurfaceBrush}">
                        <StackPanel Width="120">
                            <TextBlock Text="{Binding TotalSize}" Style="{StaticResource H2TextBlockStyle}" />
                            <TextBlock Text="Storage Used" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{DynamicResource MutedBrush}" Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" Margin="0,64,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding HasBackups}" Value="False" />
                                        <Condition Binding="{Binding IsLoading}" Value="False" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <Image Source="{StaticResource AevorIcon}" Width="64" Height="64" Opacity="0.15"
                           RenderOptions.BitmapScalingMode="HighQuality" HorizontalAlignment="Center" />

                    <TextBlock Text="No backups yet"
                               Style="{StaticResource H3TextBlockStyle}"
                               HorizontalAlignment="Center"
                               Margin="0,16,0,0" />

                    <TextBlock Text="Create a backup before cloning or making changes"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Foreground="{DynamicResource MutedBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0" />

                    <Button Content="Create First Backup"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding CreateBackupCommand}"
                            HorizontalAlignment="Center"
                            Margin="0,16,0,0" />
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" Margin="0,64,0,0"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="⏳" FontSize="32" HorizontalAlignment="Center" Foreground="{DynamicResource MutedBrush}" />
                    <TextBlock Text="Loading backups..." Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource MutedBrush}" Margin="0,12,0,0" />
                </StackPanel>

                <Grid Margin="0,8,0,12" Visibility="{Binding HasBackups, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <CheckBox Grid.Column="0"
                              IsChecked="{Binding IsAllSelected, UpdateSourceTrigger=PropertyChanged}"
                              Content="Select All"
                              FontSize="13"
                              FontFamily="{StaticResource DefaultFontFamily}"
                              VerticalAlignment="Center"
                              Margin="8,0,0,0" />
                </Grid>

                <ItemsControl ItemsSource="{Binding FilteredBackups}">
                    <ItemsControl.Style>
                        <Style TargetType="ItemsControl">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding HasBackups}" Value="True" />
                                        <Condition Binding="{Binding IsLoading}" Value="False" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ItemsControl.Style>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>

                            <Border Style="{StaticResource CardStyle}" Padding="20,24" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*"    />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                              VerticalAlignment="Center"
                                              Margin="8,0,16,0" />

                                    <Border Grid.Column="1" Width="40" Height="40" CornerRadius="20" Background="#F7E5FC" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ProfileName[0]}"
                                                   Style="{StaticResource H3TextBlockStyle}"
                                                   Foreground="{DynamicResource PrimaryBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>

                                    <StackPanel Grid.Column="2" Margin="16,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding BackupName}" Style="{StaticResource BodyTextBlockStyle}" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" />
                                        <TextBlock Text="{Binding ProfileName}" Style="{StaticResource BodySmallTextBlockStyle}" Foreground="{DynamicResource MutedBrush}" Margin="0,2,0,0" />
                                        <TextBlock Text="{Binding Notes}" Margin="0,2,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource BodySmallTextBlockStyle}">
                                                    <Setter Property="Foreground" Value="{DynamicResource MutedBrush}" />
                                                    <Style.Triggers>
                                                        <Trigger Property="Text" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </Trigger>
                                                        <Trigger Property="Text" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>

                                    <StackPanel Grid.Column="3" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,24,0">
                                        <TextBlock Text="{Binding Size}" Style="{StaticResource BodyTextBlockStyle}" Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Right" />
                                        <TextBlock Text="{Binding CreatedDate}" Style="{StaticResource BodySmallTextBlockStyle}" Foreground="{DynamicResource MutedBrush}" Margin="0,2,0,0" HorizontalAlignment="Right" />
                                    </StackPanel>

                                    <Border Grid.Column="4" CornerRadius="12" Padding="6,12" VerticalAlignment="Center" Margin="0,0,16,0" Background="{Binding ValidationBadgeBackground}">
                                        <TextBlock Text="{Binding ValidationStatus}" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="Bold" Foreground="{Binding ValidationBadgeText}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    </Border>

                                    <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="Restore"
                                                Style="{StaticResource SecondaryButton}"
                                                Command="{Binding DataContext.RestoreCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Height="32" Padding="12,0" FontSize="12"
                                                Margin="0,0,8,0" />
                                        <Button Content="Delete"
                                                Style="{StaticResource DangerButton}"
                                                Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Height="32" Padding="12,0" FontSize="12" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </Border>
        </ScrollViewer>
    </Grid>
</UserControl>

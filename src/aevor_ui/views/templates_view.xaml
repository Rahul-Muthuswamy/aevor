<UserControl x:Class="Aevor.UI.Views.TemplatesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="CardPrimaryButton" TargetType="{x:Type Button}"
               BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Height"   Value="32" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding"  Value="0"  />
        </Style>

        <Style x:Key="CardSecondaryButton" TargetType="{x:Type Button}"
               BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Height"   Value="32" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding"  Value="0"  />
        </Style>

        <Style x:Key="CardDangerButton" TargetType="{x:Type Button}"
               BasedOn="{StaticResource DangerButton}">
            <Setter Property="Height"   Value="32" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding"  Value="0"  />
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*"    />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="32,32,32,20"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Background="{DynamicResource BackgroundBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"    />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="{StaticResource AevorIcon}" Height="36" Width="36" RenderOptions.BitmapScalingMode="HighQuality" Margin="0,0,12,0"/>
                        <TextBlock Text="Templates" Style="{StaticResource H1TextBlockStyle}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Reusable browser environments ready to apply"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Foreground="{DynamicResource MutedBrush}"
                               TextWrapping="Wrap"
                               Margin="0,6,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">

                    <Border Width="240"
                            BorderBrush="{DynamicResource ControlBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CornerRadiusMD}"
                            Background="{DynamicResource SurfaceBrush}">
                        <Grid>
                            <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Padding="10,8"
                                     FontSize="13"
                                     FontFamily="{StaticResource DefaultFontFamily}"
                                     Foreground="{DynamicResource TextBrush}"
                                     VerticalContentAlignment="Center" />

                            <TextBlock Text="Search templates..."
                                       Foreground="{DynamicResource MutedBrush}"
                                       FontSize="13"
                                       FontFamily="{StaticResource DefaultFontFamily}"
                                       Padding="12,9,0,0"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SearchQuery}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SearchQuery}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <Button Content="Import"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding ImportTemplateCommand}"
                            Margin="12,0,0,0" />

                    <Button Content="New Template"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding CreateTemplateCommand}"
                            Margin="8,0,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">

            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="⏳"
                           FontSize="40"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource MutedBrush}" />
                <TextBlock Text="Loading templates..."
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{DynamicResource MutedBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0" />
            </StackPanel>

            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        MaxWidth="460">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsLoading}"   Value="False" />
                                    <Condition Binding="{Binding HasTemplates}" Value="False" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <Image Source="{StaticResource AevorIcon}" Width="64" Height="64" Opacity="0.3"
                       RenderOptions.BitmapScalingMode="HighQuality" HorizontalAlignment="Center" />

                <TextBlock Text="No templates yet"
                           Style="{StaticResource H3TextBlockStyle}"
                           HorizontalAlignment="Center"
                           Margin="0,16,0,0" />

                <TextBlock Text="Templates are created from your existing Brave profiles."
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{DynamicResource MutedBrush}"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="0,8,0,0" />

                <Border Style="{StaticResource CardStyle}" Padding="24" Margin="0,24,0,0" MaxWidth="400" HorizontalAlignment="Center">
                    <StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16" VerticalAlignment="Center">
                            <Border Width="24" Height="24" CornerRadius="12"
                                    Background="{DynamicResource PrimaryBrush}">
                                <TextBlock Text="1" FontSize="11" FontWeight="Bold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="Go to Profiles page"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16" VerticalAlignment="Center">
                            <Border Width="24" Height="24" CornerRadius="12"
                                    Background="{DynamicResource PrimaryBrush}">
                                <TextBlock Text="2" FontSize="11" FontWeight="Bold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="Click 'Create Template' on any profile"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="24" Height="24" CornerRadius="12"
                                    Background="{DynamicResource PrimaryBrush}">
                                <TextBlock Text="3" FontSize="11" FontWeight="Bold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="Your template appears here"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Button Content="Go to Profiles"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding GoToProfilesCommand}"
                        HorizontalAlignment="Center"
                        Width="180"
                        Margin="0,24,0,0" />
            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Visibility="{Binding HasTemplates, Converter={StaticResource BoolToVis}}">
                <ItemsControl ItemsSource="{Binding FilteredTemplates}"
                              Margin="32,24,32,32">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>

                            <Border Style="{StaticResource CardStyle}"
                                    Width="280"
                                    Margin="0,0,16,16"
                                    Padding="24">
                                <StackPanel>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"    />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Width="44" Height="44"
                                                CornerRadius="22"
                                                Background="#F7E5FC"
                                                HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding Initial}"
                                                       Style="{StaticResource H3TextBlockStyle}"
                                                       Foreground="{DynamicResource PrimaryBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>

                                        <Border Grid.Column="1"
                                                Background="{Binding TagBackgroundBrush}"
                                                CornerRadius="12"
                                                Padding="10,5"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding TagLabel}"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{Binding TagTextBrush}"
                                                       FontWeight="Bold" />
                                        </Border>
                                    </Grid>

                                    <TextBlock Text="{Binding TemplateName}"
                                               Style="{StaticResource H3TextBlockStyle}"
                                               Margin="0,16,0,0" />

                                    <TextBlock Text="{Binding Browser}"
                                               Style="{StaticResource BodyTextBlockStyle}"
                                               Foreground="{DynamicResource MutedBrush}"
                                               Margin="0,3,0,0" />

                                    <TextBlock Text="{Binding Description}"
                                               Style="{StaticResource BodySmallTextBlockStyle}"
                                               Foreground="{DynamicResource MutedBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxHeight="38"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0" />

                                    <Border Height="1"
                                            Background="{DynamicResource BorderBrush}"
                                            Margin="0,16" />

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding ExtensionCount}"
                                                       Style="{StaticResource H3TextBlockStyle}"
                                                       Foreground="{DynamicResource TextBrush}" />
                                            <TextBlock Text="Extensions"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{DynamicResource MutedBrush}"
                                                       Margin="0,3,0,0" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding CreatedDate}"
                                                       Style="{StaticResource BodyTextBlockStyle}"
                                                       Foreground="{DynamicResource TextBrush}"
                                                       HorizontalAlignment="Right" />
                                            <TextBlock Text="Created"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{DynamicResource MutedBrush}"
                                                       HorizontalAlignment="Right"
                                                       Margin="0,3,0,0" />
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Margin="0,8,0,0"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{DynamicResource MutedBrush}">
                                        <Run Text="v" /><Run Text="{Binding Version}" />
                                    </TextBlock>

                                    <Grid Margin="0,16,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Column="0"
                                                Content="Apply"
                                                Style="{StaticResource CardPrimaryButton}"
                                                Command="{Binding DataContext.ApplyCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" />

                                        <Button Grid.Column="2"
                                                Content="Export"
                                                Style="{StaticResource CardSecondaryButton}"
                                                Command="{Binding DataContext.ExportCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" />

                                        <Button Grid.Column="4"
                                                Content="Delete"
                                                Style="{StaticResource CardDangerButton}"
                                                Command="{Binding DataContext.DeleteCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" />
                                    </Grid>

                                </StackPanel>
                            </Border>

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

        </Grid>
    </Grid>
</UserControl>

<Window x:Class="Aevor.UI.Views.SetupPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aevor — Set Up Master Password"
        Width="480" Height="580"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Icon="/assets/aevor_logo.png">

    <!-- Drop shadow effect on outer border -->
    <Border CornerRadius="12"
            Background="White"
            Margin="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="0" Color="#1A000000" Opacity="0.35" />
        </Border.Effect>

        <!-- Drag handle so user can still move the window -->
        <Border.InputBindings>
            <MouseBinding MouseAction="LeftClick" Command="{x:Null}" />
        </Border.InputBindings>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />  <!-- close button row -->
                <RowDefinition Height="*"    />  <!-- content -->
            </Grid.RowDefinitions>

            <!-- Close button -->
            <Button Grid.Row="0"
                    x:Name="CloseButton"
                    Width="28" Height="28"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,12,16,0"
                    Style="{StaticResource GhostButton}"
                    Click="CloseButton_Click"
                    ToolTip="Close">
                <TextBlock Text="✕" FontSize="13" Foreground="{DynamicResource MutedBrush}" />
            </Button>

            <!-- Main scroll content -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="40,8,40,40">

                    <!-- ═══════════════════════════════════════
                         Top hero section
                         ═══════════════════════════════════════ -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,32,0,0">

                        <!-- Logo -->
                        <Image Source="{StaticResource AevorIcon}"
                               Width="52" Height="52"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               HorizontalAlignment="Center" />

                        <!-- Wordmark -->
                        <TextBlock Text="Aevor"
                                   Style="{StaticResource H1TextBlockStyle}"
                                   Foreground="{DynamicResource PrimaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,10,0,0" />

                        <!-- Subtitle -->
                        <TextBlock Text="Secure your Aevor vault"
                                   Style="{StaticResource H2TextBlockStyle}"
                                   Foreground="{DynamicResource TextBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0" />

                        <!-- Body copy -->
                        <TextBlock Text="Create a master password to protect your profile data and templates."
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   Foreground="{DynamicResource MutedBrush}"
                                   TextWrapping="Wrap"
                                   MaxWidth="300"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0" />
                    </StackPanel>

                    <!-- ═══════════════════════════════════════
                         Form section
                         ═══════════════════════════════════════ -->
                    <StackPanel Margin="0,36,0,0">

                        <!-- ── Master Password field ── -->
                        <TextBlock Text="Master Password"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{DynamicResource MutedBrush}"
                                   Margin="0,0,0,6" />

                        <Border x:Name="PwBorder"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12,0">
                            <Grid>
                                <TextBlock x:Name="PwPlaceholder"
                                           Text="Enter a strong password"
                                           Style="{StaticResource BodyTextBlockStyle}"
                                           Foreground="#9CA3AF"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"
                                           Margin="0,10" />
                                <PasswordBox x:Name="PasswordBox"
                                             Height="44"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             FontFamily="{StaticResource DefaultFontFamily}"
                                             FontSize="14"
                                             VerticalContentAlignment="Center"
                                             PasswordChanged="PasswordBox_PasswordChanged"
                                             GotFocus="PwBox_GotFocus"
                                             LostFocus="PwBox_LostFocus" />
                            </Grid>
                        </Border>

                        <!-- Strength bar -->
                        <ProgressBar x:Name="StrengthBar"
                                     Height="4"
                                     Value="0" Maximum="100"
                                     Margin="0,10,0,0"
                                     Background="#E5E7EB"
                                     Foreground="{DynamicResource DangerBrush}">
                            <ProgressBar.Template>
                                <ControlTemplate TargetType="ProgressBar">
                                    <Border CornerRadius="2" Background="{TemplateBinding Background}" Height="{TemplateBinding Height}">
                                        <Border x:Name="PART_Indicator"
                                                HorizontalAlignment="Left"
                                                CornerRadius="2"
                                                Background="{TemplateBinding Foreground}" />
                                    </Border>
                                </ControlTemplate>
                            </ProgressBar.Template>
                        </ProgressBar>

                        <TextBlock x:Name="StrengthLabel"
                                   Text=""
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{DynamicResource DangerBrush}"
                                   Margin="0,4,0,0" />

                        <!-- ── Confirm Password field ── -->
                        <TextBlock Text="Confirm Password"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{DynamicResource MutedBrush}"
                                   Margin="0,20,0,6" />

                        <Border x:Name="ConfirmBorder"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12,0">
                            <Grid>
                                <TextBlock x:Name="ConfirmPlaceholder"
                                           Text="Confirm your password"
                                           Style="{StaticResource BodyTextBlockStyle}"
                                           Foreground="#9CA3AF"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"
                                           Margin="0,10" />
                                <PasswordBox x:Name="ConfirmBox"
                                             Height="44"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             FontFamily="{StaticResource DefaultFontFamily}"
                                             FontSize="14"
                                             VerticalContentAlignment="Center"
                                             PasswordChanged="ConfirmBox_PasswordChanged"
                                             GotFocus="ConfirmBox_GotFocus"
                                             LostFocus="ConfirmBox_LostFocus" />
                            </Grid>
                        </Border>

                        <!-- ── Validation message ── -->
                        <TextBlock x:Name="ValidationText"
                                   Text=""
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{DynamicResource DangerBrush}"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed"
                                   Margin="0,12,0,0" />

                        <!-- ── Submit button ── -->
                        <Button x:Name="SetupBtn"
                                Content="Create Master Password"
                                Style="{StaticResource PrimaryButton}"
                                Height="44"
                                HorizontalAlignment="Stretch"
                                Margin="0,24,0,0"
                                Click="SetupBtn_Click" />

                    </StackPanel>

                    <!-- ── Bottom disclaimer ── -->
                    <TextBlock Text="This password cannot be recovered. Store it somewhere safe."
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{DynamicResource MutedBrush}"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               MaxWidth="300"
                               Margin="0,24,0,0" />

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>

<UserControl x:Class="Aevor.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="900">

    <UserControl.Resources>

        <ControlTemplate x:Key="StatCardTemplate">
            <Border Style="{StaticResource CardStyle}" Margin="0,0,12,0" />
        </ControlTemplate>

        <Style x:Key="QuickActionRowStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusMD}" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F9FAFB" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SeparatorLine" TargetType="{x:Type Border}">
            <Setter Property="Height" Value="1" />
            <Setter Property="Background" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Margin" Value="24,0" />
        </Style>

    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Background="{DynamicResource BackgroundBrush}">
        <StackPanel Margin="32" MaxWidth="1100">

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Image Source="{StaticResource AevorIcon}" Height="36" Width="36" RenderOptions.BitmapScalingMode="HighQuality" Margin="0,0,12,0"/>
                <TextBlock Text="Dashboard" Style="{StaticResource H1TextBlockStyle}" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="Welcome back. Here's what's happening with your profiles."
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{DynamicResource MutedBrush}"
                       Margin="0,6,0,0" />

            <UniformGrid Columns="4" Margin="0,32,0,0">

                <Border Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="PROFILES"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource MutedBrush}" />
                        <TextBlock Text="{Binding TotalProfiles}"
                                   Style="{StaticResource H1TextBlockStyle}"
                                   Margin="0,10,0,0" />
                        <TextBlock Text="Brave profiles discovered"
                                   Style="{StaticResource BodySmallTextBlockStyle}"
                                   Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Margin="6,0">
                    <StackPanel>
                        <TextBlock Text="TEMPLATES"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource MutedBrush}" />
                        <TextBlock Text="{Binding TotalTemplates}"
                                   Style="{StaticResource H1TextBlockStyle}"
                                   Margin="0,10,0,0" />
                        <TextBlock Text="Reusable environments"
                                   Style="{StaticResource BodySmallTextBlockStyle}"
                                   Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Margin="6,0">
                    <StackPanel>
                        <TextBlock Text="BACKUPS"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource MutedBrush}" />
                        <TextBlock Text="{Binding TotalBackups}"
                                   Style="{StaticResource H1TextBlockStyle}"
                                   Margin="0,10,0,0" />
                        <TextBlock Text="Profile snapshots"
                                   Style="{StaticResource BodySmallTextBlockStyle}"
                                   Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Margin="12,0,0,0">
                    <StackPanel>
                        <TextBlock Text="SECURITY"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource MutedBrush}" />
                        <TextBlock Text="{Binding SecurityStatus}"
                                   Style="{StaticResource H1TextBlockStyle}"
                                   FontSize="22"
                                   Foreground="{Binding SecurityStatusColor}"
                                   Margin="0,10,0,0" />
                        <TextBlock Text="Overall risk assessment"
                                   Style="{StaticResource BodySmallTextBlockStyle}"
                                   Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

            </UniformGrid>

            <Grid Margin="0,32,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">

                    <TextBlock Text="Recent Activity"
                               Style="{StaticResource H3TextBlockStyle}"
                               Margin="0,0,0,12" />

                    <Border Style="{StaticResource CardStyle}" Padding="0">
                        <StackPanel>

                            <ItemsControl ItemsSource="{Binding RecentActivities}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>

                                            <Grid Margin="24,14">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Ellipse Grid.Column="0"
                                                         Width="8" Height="8"
                                                         Fill="{Binding DotColor}"
                                                         VerticalAlignment="Center"
                                                         Margin="0,0,14,0" />

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Title}"
                                                               Style="{StaticResource BodyTextBlockStyle}"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding Description}"
                                                               Style="{StaticResource BodySmallTextBlockStyle}"
                                                               Foreground="{DynamicResource MutedBrush}"
                                                               Margin="0,3,0,0"
                                                               TextTrimming="CharacterEllipsis" />
                                                </StackPanel>

                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding TimeAgo}"
                                                           Style="{StaticResource CaptionTextBlockStyle}"
                                                           Foreground="{DynamicResource MutedBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="16,0,0,0" />
                                            </Grid>

                                            <Border Style="{StaticResource SeparatorLine}" />

                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </Border>

                </StackPanel>

                <Grid Grid.Column="1" />

                <StackPanel Grid.Column="2">

                    <TextBlock Text="Quick Actions"
                               Style="{StaticResource H3TextBlockStyle}"
                               Margin="0,0,0,12" />

                    <Border Style="{StaticResource CardStyle}" Padding="4">
                        <StackPanel>

                            <Border Style="{StaticResource QuickActionRowStyle}">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick" Command="{Binding DataContext.AnalyzeProfilesCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                </Border.InputBindings>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Grid.Column="0" Width="20" Height="20"
                                               Fill="{DynamicResource PrimaryBrush}"
                                               Opacity="0.7" RadiusX="4" RadiusY="4"
                                               Margin="0,0,14,0" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Analyze Profiles"
                                                   Style="{StaticResource BodyTextBlockStyle}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="Scan and analyze all profiles"
                                                   Style="{StaticResource BodySmallTextBlockStyle}"
                                                   Foreground="{DynamicResource MutedBrush}"
                                                   Margin="0,2,0,0" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="›"
                                               FontSize="18" FontWeight="Light"
                                               Foreground="{DynamicResource MutedBrush}"
                                               VerticalAlignment="Center"
                                               Margin="12,0,0,0" />
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource QuickActionRowStyle}">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick" Command="{Binding DataContext.CreateTemplateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                </Border.InputBindings>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Grid.Column="0" Width="20" Height="20"
                                               Fill="{DynamicResource PrimaryBrush}"
                                               Opacity="0.7" RadiusX="4" RadiusY="4"
                                               Margin="0,0,14,0" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Create Template"
                                                   Style="{StaticResource BodyTextBlockStyle}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="Save a profile as a template"
                                                   Style="{StaticResource BodySmallTextBlockStyle}"
                                                   Foreground="{DynamicResource MutedBrush}"
                                                   Margin="0,2,0,0" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="›"
                                               FontSize="18" FontWeight="Light"
                                               Foreground="{DynamicResource MutedBrush}"
                                               VerticalAlignment="Center"
                                               Margin="12,0,0,0" />
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource QuickActionRowStyle}">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick" Command="{Binding DataContext.CreateBackupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                </Border.InputBindings>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Grid.Column="0" Width="20" Height="20"
                                               Fill="{DynamicResource PrimaryBrush}"
                                               Opacity="0.7" RadiusX="4" RadiusY="4"
                                               Margin="0,0,14,0" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Create Backup"
                                                   Style="{StaticResource BodyTextBlockStyle}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="Backup a profile safely"
                                                   Style="{StaticResource BodySmallTextBlockStyle}"
                                                   Foreground="{DynamicResource MutedBrush}"
                                                   Margin="0,2,0,0" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="›"
                                               FontSize="18" FontWeight="Light"
                                               Foreground="{DynamicResource MutedBrush}"
                                               VerticalAlignment="Center"
                                               Margin="12,0,0,0" />
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource QuickActionRowStyle}">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick" Command="{Binding DataContext.ViewSecurityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                </Border.InputBindings>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Grid.Column="0" Width="20" Height="20"
                                               Fill="{DynamicResource PrimaryBrush}"
                                               Opacity="0.7" RadiusX="4" RadiusY="4"
                                               Margin="0,0,14,0" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Security Report"
                                                   Style="{StaticResource BodyTextBlockStyle}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="View detailed security findings"
                                                   Style="{StaticResource BodySmallTextBlockStyle}"
                                                   Foreground="{DynamicResource MutedBrush}"
                                                   Margin="0,2,0,0" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="›"
                                               FontSize="18" FontWeight="Light"
                                               Foreground="{DynamicResource MutedBrush}"
                                               VerticalAlignment="Center"
                                               Margin="12,0,0,0" />
                                </Grid>
                            </Border>

                        </StackPanel>
                    </Border>

                </StackPanel>

            </Grid>

            <Border Height="32" />

        </StackPanel>
    </ScrollViewer>

</UserControl>

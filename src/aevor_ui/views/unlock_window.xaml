<Window x:Class="Aevor.UI.Views.UnlockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aevor — Unlock"
        Width="480" Height="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Icon="/assets/aevor_logo.png">

    <Border CornerRadius="12"
            Background="White"
            Margin="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="0" Color="#1A000000" Opacity="0.35" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*"    />
            </Grid.RowDefinitions>

            <Button Grid.Row="0"
                    Width="32" Height="32"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,12,16,0"
                    Style="{StaticResource GhostButton}"
                    Padding="0"
                    Click="CloseButton_Click"
                    ToolTip="Quit Aevor">
                <Path Data="M0,0 L10,10 M10,0 L0,10"
                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                      StrokeThickness="1.5"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Width="10"
                      Height="10" />
            </Button>

            <StackPanel Grid.Row="1" Margin="40,8,40,40">

                <StackPanel HorizontalAlignment="Center" Margin="0,24,0,0">

                    <Border Width="64" Height="64"
                            CornerRadius="32"
                            Background="#EDE9FE"
                            HorizontalAlignment="Center">
                        <TextBlock Text="🔒"
                                   FontSize="28"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>

                    <TextBlock Text="Welcome back"
                               Style="{StaticResource H2TextBlockStyle}"
                               Foreground="{DynamicResource TextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,16,0,0" />

                    <TextBlock Text="Enter your master password to continue"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Foreground="{DynamicResource MutedBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0" />
                </StackPanel>

                <StackPanel Margin="0,36,0,0">

                    <TextBlock Text="Master Password"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{DynamicResource MutedBrush}"
                               Margin="0,0,0,6" />

                    <Border x:Name="PwBorder"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12,0">
                        <Grid>
                            <TextBlock x:Name="PwPlaceholder"
                                       Text="Enter your master password"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Foreground="#9CA3AF"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"
                                       Margin="0,10" />
                            <PasswordBox x:Name="PasswordBox"
                                         Height="44"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         FontFamily="{StaticResource DefaultFontFamily}"
                                         FontSize="14"
                                         VerticalContentAlignment="Center"
                                         PasswordChanged="PasswordBox_PasswordChanged"
                                         GotFocus="PwBox_GotFocus"
                                         LostFocus="PwBox_LostFocus"
                                         KeyDown="PasswordBox_KeyDown" />
                        </Grid>
                    </Border>

                    <TextBlock x:Name="ValidationText"
                               Text=""
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{DynamicResource DangerBrush}"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"
                               Margin="0,10,0,0" />

                    <TextBlock x:Name="LockoutText"
                               Text=""
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{DynamicResource WarningBrush}"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"
                               TextAlignment="Center"
                               Margin="0,10,0,0" />

                    <Button x:Name="UnlockBtn"
                            Content="Unlock Aevor"
                            Style="{StaticResource PrimaryButton}"
                            Height="44"
                            HorizontalAlignment="Stretch"
                            Margin="0,24,0,0"
                            Click="UnlockBtn_Click" />

                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>

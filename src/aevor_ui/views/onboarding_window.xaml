<Window x:Class="Aevor.UI.Views.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aevor — Welcome"
        Width="700" Height="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Icon="/assets/aevor_logo.png">

    <Border CornerRadius="12"
            Background="White"
            Margin="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="0" Color="#1A000000" Opacity="0.35" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*"    />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Button Grid.Row="0"
                    Width="28" Height="28"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,12,16,0"
                    Style="{StaticResource GhostButton}"
                    Click="CloseButton_Click"
                    ToolTip="Skip onboarding">
                <TextBlock Text="✕" FontSize="13" Foreground="{DynamicResource MutedBrush}" />
            </Button>

            <Grid Grid.Row="1" Margin="48,0">

                <StackPanel x:Name="Slide1"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Visibility="Visible">

                    <Border Width="64" Height="64" CornerRadius="32"
                            Background="#F3EAFF"
                            HorizontalAlignment="Center">
                        <Image Source="{StaticResource AevorIcon}" Width="36" Height="36"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>

                    <TextBlock Text="Welcome to Aevor"
                               Style="{StaticResource H2TextBlockStyle}"
                               Foreground="{DynamicResource TextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,20,0,0" />

                    <TextBlock Text="Aevor helps you manage, clone, and protect your Brave browser profiles."
                               Style="{StaticResource BodyTextBlockStyle}"
                               Foreground="{DynamicResource MutedBrush}"
                               TextWrapping="Wrap"
                               MaxWidth="420"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               Margin="0,12,0,0" />
                </StackPanel>

                <StackPanel x:Name="Slide2"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Visibility="Collapsed">

                    <Border Width="64" Height="64" CornerRadius="32"
                            Background="#EDE9FE"
                            HorizontalAlignment="Center">
                        <TextBlock Text="📋" FontSize="28"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>

                    <TextBlock Text="Templates &amp; Cloning"
                               Style="{StaticResource H2TextBlockStyle}"
                               Foreground="{DynamicResource TextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,20,0,0" />

                    <TextBlock Text="Turn any profile into a reusable template. Clone it in seconds without rebuilding your setup from scratch."
                               Style="{StaticResource BodyTextBlockStyle}"
                               Foreground="{DynamicResource MutedBrush}"
                               TextWrapping="Wrap"
                               MaxWidth="420"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               Margin="0,12,0,0" />
                </StackPanel>

                <StackPanel x:Name="Slide3"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Visibility="Collapsed">

                    <Border Width="64" Height="64" CornerRadius="32"
                            Background="#D1FAE5"
                            HorizontalAlignment="Center">
                        <TextBlock Text="🛡️" FontSize="28"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>

                    <TextBlock Text="Security First"
                               Style="{StaticResource H2TextBlockStyle}"
                               Foreground="{DynamicResource TextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,20,0,0" />

                    <TextBlock Text="Aevor scans every profile for sensitive data and never exports passwords, cookies, or wallet data."
                               Style="{StaticResource BodyTextBlockStyle}"
                               Foreground="{DynamicResource MutedBrush}"
                               TextWrapping="Wrap"
                               MaxWidth="420"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               Margin="0,12,0,0" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="2" Margin="48,0,48,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left">
                    <Ellipse x:Name="Dot1" Width="10" Height="10" Margin="0,0,8,0"
                             Fill="{DynamicResource PrimaryBrush}" />
                    <Ellipse x:Name="Dot2" Width="10" Height="10" Margin="0,0,8,0"
                             Fill="{DynamicResource BorderBrush}" />
                    <Ellipse x:Name="Dot3" Width="10" Height="10"
                             Fill="{DynamicResource BorderBrush}" />
                </StackPanel>

                <Button x:Name="NextBtn"
                        Grid.Column="1"
                        Content="Next"
                        Style="{StaticResource PrimaryButton}"
                        Width="140" Height="40"
                        Click="NextBtn_Click" />
            </Grid>
        </Grid>
    </Border>
</Window>

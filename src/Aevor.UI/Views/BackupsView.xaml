<UserControl x:Class="Aevor.UI.Views.BackupsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="900">

    <UserControl.Resources>
        <!-- Boolean to Visibility Converter -->
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <!-- Root Grid: Two rows (auto header + * content) -->
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*"    />
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════════
             Row 1 — Header (padding 32 32 24 32)
             ══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Padding="32,32,32,24" Background="White">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"    />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Left Column -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="{StaticResource AevorIcon}" Height="36" Width="36" RenderOptions.BitmapScalingMode="HighQuality" Margin="0,0,12,0"/>
                        <TextBlock Text="Backups" Style="{StaticResource H1TextBlockStyle}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Profile snapshots you can restore at any time"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Foreground="{StaticResource MutedBrush}"
                               Margin="0,4,0,0" />
                </StackPanel>

                <!-- Right Column -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Search Input -->
                    <Border Width="240"
                            BorderBrush="{StaticResource ControlBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CornerRadiusMD}"
                            Background="{StaticResource SurfaceBrush}">
                        <Grid>
                            <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Padding="10,8"
                                     FontSize="13"
                                     FontFamily="{StaticResource DefaultFontFamily}"
                                     Foreground="{StaticResource TextBrush}"
                                     VerticalContentAlignment="Center"
                                     x:Name="SearchBox" />
                            <!-- Placeholder -->
                            <TextBlock Text="Search backups..."
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="13"
                                       FontFamily="{StaticResource DefaultFontFamily}"
                                       Padding="12,9,0,0"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SearchQuery}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SearchQuery}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Create Backup Button -->
                    <Button Content="Create Backup"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding CreateBackupCommand}"
                            Margin="12,0,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════
             Row 2 — Content Area (padding 32)
             ══════════════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Border Padding="32,0,32,32" Background="White">
                <StackPanel>
                
                <!-- Summary Row (margin bottom 24) -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                    <!-- Card 1: Total Backups -->
                    <Border Style="{StaticResource CardStyle}" Padding="16,20" Margin="0,0,12,0" Background="{StaticResource SurfaceBrush}">
                        <StackPanel Width="120">
                            <TextBlock Text="{Binding TotalBackups}" Style="{StaticResource H2TextBlockStyle}" />
                            <TextBlock Text="Total Backups" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{StaticResource MutedBrush}" Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Card 2: Storage Used -->
                    <Border Style="{StaticResource CardStyle}" Padding="16,20" Margin="0,0,12,0" Background="{StaticResource SurfaceBrush}">
                        <StackPanel Width="120">
                            <TextBlock Text="{Binding TotalSize}" Style="{StaticResource H2TextBlockStyle}" />
                            <TextBlock Text="Storage Used" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{StaticResource MutedBrush}" Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Empty State (HasBackups=false, IsLoading=false) -->
                <StackPanel HorizontalAlignment="Center" Margin="0,64,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding HasBackups}" Value="False" />
                                        <Condition Binding="{Binding IsLoading}" Value="False" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    
                    <!-- Icon Placeholder -->
                    <Image Source="{StaticResource AevorIcon}" Width="64" Height="64" Opacity="0.15"
                           RenderOptions.BitmapScalingMode="HighQuality" HorizontalAlignment="Center" />
                    
                    <TextBlock Text="No backups yet"
                               Style="{StaticResource H3TextBlockStyle}"
                               HorizontalAlignment="Center"
                               Margin="0,16,0,0" />
                    
                    <TextBlock Text="Create a backup before cloning or making changes"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Foreground="{StaticResource MutedBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0" />
                    
                    <Button Content="Create First Backup"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding CreateBackupCommand}"
                            HorizontalAlignment="Center"
                            Margin="0,16,0,0" />
                </StackPanel>

                <!-- Loading State -->
                <StackPanel HorizontalAlignment="Center" Margin="0,64,0,0"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="⏳" FontSize="32" HorizontalAlignment="Center" Foreground="{StaticResource MutedBrush}" />
                    <TextBlock Text="Loading backups..." Style="{StaticResource BodyTextBlockStyle}" Foreground="{StaticResource MutedBrush}" Margin="0,12,0,0" />
                </StackPanel>

                <!-- Backup List (HasBackups=true, IsLoading=false) -->
                <ItemsControl ItemsSource="{Binding FilteredBackups}">
                    <ItemsControl.Style>
                        <Style TargetType="ItemsControl">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding HasBackups}" Value="True" />
                                        <Condition Binding="{Binding IsLoading}" Value="False" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ItemsControl.Style>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Backup Card Row -->
                            <Border Style="{StaticResource CardStyle}" Padding="20,24" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" /> <!-- Col 1: Avatar -->
                                        <ColumnDefinition Width="*"    /> <!-- Col 2: Info   -->
                                        <ColumnDefinition Width="Auto" /> <!-- Col 3: Size & Date -->
                                        <ColumnDefinition Width="Auto" /> <!-- Col 4: Badge  -->
                                        <ColumnDefinition Width="Auto" /> <!-- Col 5: Actions -->
                                    </Grid.ColumnDefinitions>

                                    <!-- Col 1: Avatar circle -->
                                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" Background="#F7E5FC" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ProfileName[0]}" 
                                                   Style="{StaticResource H3TextBlockStyle}" 
                                                   Foreground="{StaticResource PrimaryBrush}" 
                                                   HorizontalAlignment="Center" 
                                                   VerticalAlignment="Center" />
                                    </Border>

                                    <!-- Col 2: Info (margin left 16) -->
                                    <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding BackupName}" Style="{StaticResource BodyTextBlockStyle}" FontWeight="Bold" Foreground="{StaticResource TextBrush}" />
                                        <TextBlock Text="{Binding ProfileName}" Style="{StaticResource BodySmallTextBlockStyle}" Foreground="{StaticResource MutedBrush}" Margin="0,2,0,0" />
                                        <TextBlock Text="{Binding Notes}" Margin="0,2,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource BodySmallTextBlockStyle}">
                                                    <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
                                                    <Style.Triggers>
                                                        <Trigger Property="Text" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </Trigger>
                                                        <Trigger Property="Text" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Col 3: Size and date (right aligned, margin right 24) -->
                                    <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,24,0">
                                        <TextBlock Text="{Binding Size}" Style="{StaticResource BodyTextBlockStyle}" Foreground="{StaticResource TextBrush}" HorizontalAlignment="Right" />
                                        <TextBlock Text="{Binding CreatedDate}" Style="{StaticResource BodySmallTextBlockStyle}" Foreground="{StaticResource MutedBrush}" Margin="0,2,0,0" HorizontalAlignment="Right" />
                                    </StackPanel>

                                    <!-- Col 4: Validation badge (margin right 16) -->
                                    <Border Grid.Column="3" CornerRadius="12" Padding="6,12" VerticalAlignment="Center" Margin="0,0,16,0" Background="{Binding ValidationBadgeBackground}">
                                        <TextBlock Text="{Binding ValidationStatus}" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="Bold" Foreground="{Binding ValidationBadgeText}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    </Border>

                                    <!-- Col 5: Actions -->
                                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="Delete" 
                                                Style="{StaticResource DangerButton}" 
                                                Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                CommandParameter="{Binding}"
                                                Height="32" Padding="12,0" FontSize="12" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                
            </StackPanel>
        </Border>
        </ScrollViewer>
    </Grid>
</UserControl>

<UserControl x:Class="Aevor.UI.Views.SecurityView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="900">

    <UserControl.Resources>
        <!-- Filter Pill Button Style -->
        <Style x:Key="FilterPillStyle" TargetType="Button">
            <Setter Property="Height" Value="32" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#E5E7EB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="Padding" Value="16,6" />
            <Setter Property="FontFamily" Value="{StaticResource DefaultFontFamily}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="16" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- Root: ScrollViewer > StackPanel -->
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Background="White">
        <Border Padding="32" Background="White">
            <StackPanel>

            <!-- ══════════════════════════════════════════════════════════════
                 Section 1 — Header
                 ══════════════════════════════════════════════════════════════ -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"    />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Left -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Security Reports" Style="{StaticResource H1TextBlockStyle}" />
                    <TextBlock Text="Scan results and risk assessment for all profiles"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Foreground="{StaticResource MutedBrush}"
                               Margin="0,4,0,0" />
                </StackPanel>

                <!-- Right -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Run Scan"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding RunScanCommand}" />
                    
                    <Button Content="Export Report"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding ExportReportCommand}"
                            Margin="8,0,0,0" />
                </StackPanel>
            </Grid>

            <!-- ══════════════════════════════════════════════════════════════
                 Section 2 — Overall Risk Banner (margin top 32)
                 ══════════════════════════════════════════════════════════════ -->
            <Border Margin="0,32,0,0" 
                    Style="{StaticResource CardStyle}" 
                    Padding="24" 
                    Background="{Binding OverallRiskBackground}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"    />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Left side: Risk score overview -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding OverallRiskScore}" 
                                       Style="{StaticResource H1TextBlockStyle}" 
                                       Foreground="{Binding OverallRiskColor}" 
                                       FontSize="36" />
                            <TextBlock Text=" / 100" 
                                       Style="{StaticResource H2TextBlockStyle}" 
                                       Foreground="{StaticResource MutedBrush}" 
                                       VerticalAlignment="Bottom" 
                                       Margin="0,0,0,6" />
                        </StackPanel>
                        
                        <TextBlock Text="{Binding OverallRiskLabel}" 
                                   Style="{StaticResource H3TextBlockStyle}" 
                                   Foreground="{Binding OverallRiskColor}" 
                                   Margin="0,4,0,0" />
                        
                        <TextBlock Text="Overall Security Score" 
                                   Style="{StaticResource BodyTextBlockStyle}" 
                                   Foreground="{StaticResource MutedBrush}" 
                                   Margin="0,2,0,0" />
                    </StackPanel>

                    <!-- Right side: Four stat tiles -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Stat 1: Total Findings -->
                        <StackPanel Margin="0,0,24,0" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding TotalFindings}" Style="{StaticResource H2TextBlockStyle}" Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center" />
                            <TextBlock Text="Total Findings" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center" Margin="0,2,0,0" />
                        </StackPanel>

                        <!-- Stat 2: Critical -->
                        <StackPanel Margin="0,0,24,0" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding CriticalCount}" Style="{StaticResource H2TextBlockStyle}" Foreground="{StaticResource DangerBrush}" HorizontalAlignment="Center" />
                            <TextBlock Text="Critical" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center" Margin="0,2,0,0" />
                        </StackPanel>

                        <!-- Stat 3: Warnings -->
                        <StackPanel Margin="0,0,24,0" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding WarningCount}" Style="{StaticResource H2TextBlockStyle}" Foreground="{StaticResource WarningBrush}" HorizontalAlignment="Center" />
                            <TextBlock Text="Warnings" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center" Margin="0,2,0,0" />
                        </StackPanel>

                        <!-- Stat 4: Excluded -->
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding ExcludedCount}" Style="{StaticResource H2TextBlockStyle}" Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center" />
                            <TextBlock Text="Excluded" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center" Margin="0,2,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════════════════════════
                 Section 3 — Profile Risk Summary (margin top 32)
                 ══════════════════════════════════════════════════════════════ -->
            <TextBlock Text="Profile Risk Overview" Style="{StaticResource H3TextBlockStyle}" Margin="0,32,0,0" />
            
            <ItemsControl ItemsSource="{Binding ProfileSummaries}" Margin="0,16,0,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Profile Card -->
                        <Border Style="{StaticResource CardStyle}" Width="200" Padding="20" Margin="0,0,12,12" Background="{StaticResource SurfaceBrush}">
                            <StackPanel>
                                <!-- Profile Avatar -->
                                <Border Width="36" Height="36" CornerRadius="18" Background="#EDE9FE" HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding Initial}" 
                                               Style="{StaticResource BodyTextBlockStyle}" 
                                               FontWeight="Bold" 
                                               Foreground="{StaticResource PrimaryBrush}" 
                                               HorizontalAlignment="Center" 
                                               VerticalAlignment="Center" />
                                </Border>

                                <!-- Profile Name -->
                                <TextBlock Text="{Binding ProfileName}" Style="{StaticResource BodyTextBlockStyle}" FontWeight="Bold" Margin="0,12,0,0" />

                                <!-- Risk Score -->
                                <TextBlock Text="{Binding RiskScore, StringFormat='Score: {0}'}" Style="{StaticResource H2TextBlockStyle}" Foreground="{Binding RiskColor}" Margin="0,8,0,0" />

                                <!-- Risk Label -->
                                <TextBlock Text="{Binding RiskLabel}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{Binding RiskColor}" FontWeight="Bold" />

                                <!-- Findings Count -->
                                <TextBlock Style="{StaticResource BodySmallTextBlockStyle}" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0">
                                    <Run Text="{Binding FindingCount}" />
                                    <Run Text=" findings" />
                                </TextBlock>

                                <!-- Last Scanned -->
                                <TextBlock Text="{Binding LastScanned}" Style="{StaticResource BodySmallTextBlockStyle}" Foreground="{StaticResource MutedBrush}" Margin="0,2,0,0" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ══════════════════════════════════════════════════════════════
                 Section 4 — Findings (margin top 32)
                 ══════════════════════════════════════════════════════════════ -->
            <Grid Margin="0,32,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"    />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Findings" Style="{StaticResource H3TextBlockStyle}" VerticalAlignment="Center" />

                <!-- Filter Pill Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Button All -->
                    <Button Content="All" Command="{Binding FilterBySeverityCommand}" CommandParameter="All">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource FilterPillStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFilterAllActive}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
                                        <Setter Property="Foreground" Value="White" />
                                        <Setter Property="BorderThickness" Value="0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Button Critical -->
                    <Button Content="Critical" Command="{Binding FilterBySeverityCommand}" CommandParameter="Critical" Margin="8,0,0,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource FilterPillStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFilterCriticalActive}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
                                        <Setter Property="Foreground" Value="White" />
                                        <Setter Property="BorderThickness" Value="0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Button Warning -->
                    <Button Content="Warning" Command="{Binding FilterBySeverityCommand}" CommandParameter="Warning" Margin="8,0,0,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource FilterPillStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFilterWarningActive}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
                                        <Setter Property="Foreground" Value="White" />
                                        <Setter Property="BorderThickness" Value="0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Button Info -->
                    <Button Content="Info" Command="{Binding FilterBySeverityCommand}" CommandParameter="Info" Margin="8,0,0,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource FilterPillStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFilterInfoActive}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
                                        <Setter Property="Foreground" Value="White" />
                                        <Setter Property="BorderThickness" Value="0" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Findings List (margin top 16) -->
            <ItemsControl ItemsSource="{Binding FilteredFindings}" Margin="0,16,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Finding Card Row -->
                        <Border Style="{StaticResource CardStyle}" Padding="16,20" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" /> <!-- Ellipse dot -->
                                    <ColumnDefinition Width="*"    /> <!-- Middle Text -->
                                    <ColumnDefinition Width="Auto" /> <!-- Severity Badge -->
                                </Grid.ColumnDefinitions>

                                <!-- Col 1: Ellipse Dot -->
                                <Ellipse Grid.Column="0" Width="10" Height="10" Fill="{Binding SeverityColor}" VerticalAlignment="Center" Margin="4,0,16,0" />

                                <!-- Col 2: Middle Text -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding FindingTitle}" Style="{StaticResource BodyTextBlockStyle}" FontWeight="Bold" Foreground="{StaticResource TextBrush}" />
                                    <TextBlock Text="{Binding FindingDetail}" Style="{StaticResource BodySmallTextBlockStyle}" Foreground="{StaticResource MutedBrush}" Margin="0,2,0,0" />
                                    
                                    <TextBlock Style="{StaticResource BodySmallTextBlockStyle}" Foreground="{StaticResource MutedBrush}" Margin="0,2,0,0">
                                        <Run Text="Affected: " />
                                        <Run Text="{Binding AffectedProfile}" />
                                    </TextBlock>
                                </StackPanel>

                                <!-- Col 3: Severity Badge -->
                                <Border Grid.Column="2" CornerRadius="12" Padding="10,6" VerticalAlignment="Center" Background="{Binding SeverityBadgeBackground}">
                                    <TextBlock Text="{Binding Severity}" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="Bold" Foreground="{Binding SeverityBadgeText}" />
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
        </Border>
    </ScrollViewer>
</UserControl>

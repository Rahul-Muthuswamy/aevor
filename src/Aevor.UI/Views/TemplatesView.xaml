<UserControl x:Class="Aevor.UI.Views.TemplatesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Compact button variants for card actions (height 32) -->
        <Style x:Key="CardPrimaryButton" TargetType="{x:Type Button}"
               BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Height"   Value="32" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding"  Value="0"  />
        </Style>

        <Style x:Key="CardSecondaryButton" TargetType="{x:Type Button}"
               BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Height"   Value="32" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding"  Value="0"  />
        </Style>

        <Style x:Key="CardDangerButton" TargetType="{x:Type Button}"
               BasedOn="{StaticResource DangerButton}">
            <Setter Property="Height"   Value="32" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding"  Value="0"  />
        </Style>
    </UserControl.Resources>

    <!-- ─── Root: two rows ─── -->
    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*"    />
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════════
             Row 1 — Page Header
             ══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Padding="32,32,32,20"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Background="{StaticResource BackgroundBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"    />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Left: Title + Subtitle -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Templates"
                               Style="{StaticResource H1TextBlockStyle}" />
                    <TextBlock Text="Reusable browser environments ready to apply"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Foreground="{StaticResource MutedBrush}"
                               Margin="0,6,0,0" />
                </StackPanel>

                <!-- Right: Search + Import + New -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- Search TextBox -->
                    <Border Width="240"
                            BorderBrush="{StaticResource ControlBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CornerRadiusMD}"
                            Background="{StaticResource SurfaceBrush}">
                        <Grid>
                            <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Padding="10,8"
                                     FontSize="13"
                                     FontFamily="{StaticResource DefaultFontFamily}"
                                     Foreground="{StaticResource TextBrush}"
                                     VerticalContentAlignment="Center" />
                            <!-- Placeholder -->
                            <TextBlock Text="Search templates..."
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="13"
                                       FontFamily="{StaticResource DefaultFontFamily}"
                                       Padding="12,9,0,0"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SearchQuery}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SearchQuery}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Import Button -->
                    <Button Content="Import"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding ImportTemplateCommand}"
                            Margin="12,0,0,0" />

                    <!-- New Template Button -->
                    <Button Content="New Template"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding RefreshCommand}"
                            Margin="8,0,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════
             Row 2 — Content
             ══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">

            <!-- ── Loading State ── -->
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="⏳"
                           FontSize="40"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource MutedBrush}" />
                <TextBlock Text="Loading templates..."
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{StaticResource MutedBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0" />
            </StackPanel>

            <!-- ── Empty State ── -->
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsLoading}"   Value="False" />
                                    <Condition Binding="{Binding HasTemplates}" Value="False" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <Rectangle Width="48" Height="48"
                           Fill="{StaticResource MutedBrush}"
                           Opacity="0.3"
                           RadiusX="8" RadiusY="8"
                           HorizontalAlignment="Center" />
                <TextBlock Text="No templates yet"
                           Style="{StaticResource H3TextBlockStyle}"
                           HorizontalAlignment="Center"
                           Margin="0,16,0,0" />
                <TextBlock Text="Create a template from an existing profile to get started"
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{StaticResource MutedBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0" />
                <Button Content="Create First Template"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding RefreshCommand}"
                        HorizontalAlignment="Center"
                        Margin="0,16,0,0" />
            </StackPanel>

            <!-- ── Template Grid ── -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Visibility="{Binding HasTemplates, Converter={StaticResource BoolToVis}}">
                <ItemsControl ItemsSource="{Binding FilteredTemplates}"
                              Margin="32,24,32,32">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>

                            <!-- ─── Template Card ─── -->
                            <Border Style="{StaticResource CardStyle}"
                                    Width="280"
                                    Margin="0,0,16,16"
                                    Padding="24">
                                <StackPanel>

                                    <!-- Top Row: Avatar + Tag Badge -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"    />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Avatar circle -->
                                        <Border Grid.Column="0"
                                                Width="44" Height="44"
                                                CornerRadius="22"
                                                Background="#EDE9FE"
                                                HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding Initial}"
                                                       Style="{StaticResource H3TextBlockStyle}"
                                                       Foreground="{StaticResource PrimaryBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>

                                        <!-- Tag Badge -->
                                        <Border Grid.Column="1"
                                                Background="{Binding TagBackgroundBrush}"
                                                CornerRadius="12"
                                                Padding="10,5"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding TagLabel}"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{Binding TagTextBrush}"
                                                       FontWeight="Bold" />
                                        </Border>
                                    </Grid>

                                    <!-- Template Name -->
                                    <TextBlock Text="{Binding TemplateName}"
                                               Style="{StaticResource H3TextBlockStyle}"
                                               Margin="0,16,0,0" />

                                    <!-- Browser -->
                                    <TextBlock Text="{Binding Browser}"
                                               Style="{StaticResource BodyTextBlockStyle}"
                                               Foreground="{StaticResource MutedBrush}"
                                               Margin="0,3,0,0" />

                                    <!-- Description -->
                                    <TextBlock Text="{Binding Description}"
                                               Style="{StaticResource BodySmallTextBlockStyle}"
                                               Foreground="{StaticResource MutedBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxHeight="38"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0" />

                                    <!-- Divider -->
                                    <Border Height="1"
                                            Background="{StaticResource BorderBrush}"
                                            Margin="0,16" />

                                    <!-- Stats Row -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Extensions -->
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding ExtensionCount}"
                                                       Style="{StaticResource H3TextBlockStyle}"
                                                       Foreground="{StaticResource TextBrush}" />
                                            <TextBlock Text="Extensions"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       Margin="0,3,0,0" />
                                        </StackPanel>

                                        <!-- Created Date -->
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding CreatedDate}"
                                                       Style="{StaticResource BodyTextBlockStyle}"
                                                       Foreground="{StaticResource TextBrush}"
                                                       HorizontalAlignment="Right" />
                                            <TextBlock Text="Created"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       HorizontalAlignment="Right"
                                                       Margin="0,3,0,0" />
                                        </StackPanel>
                                    </Grid>

                                    <!-- Version Row -->
                                    <TextBlock Margin="0,8,0,0"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{StaticResource MutedBrush}">
                                        <Run Text="v" /><Run Text="{Binding Version}" />
                                    </TextBlock>

                                    <!-- Action Buttons Row -->
                                    <Grid Margin="0,16,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Apply -->
                                        <Button Grid.Column="0"
                                                Content="Apply"
                                                Style="{StaticResource CardPrimaryButton}"
                                                Command="{Binding DataContext.ApplyCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" />

                                        <!-- Export -->
                                        <Button Grid.Column="2"
                                                Content="Export"
                                                Style="{StaticResource CardSecondaryButton}"
                                                Command="{Binding DataContext.ExportCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" />

                                        <!-- Delete -->
                                        <Button Grid.Column="4"
                                                Content="Delete"
                                                Style="{StaticResource CardDangerButton}"
                                                Command="{Binding DataContext.DeleteCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" />
                                    </Grid>

                                </StackPanel>
                            </Border>

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

        </Grid>
    </Grid>
</UserControl>

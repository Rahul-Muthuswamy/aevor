<Window x:Class="Aevor.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:Aevor.UI.ViewModels"
        xmlns:views="clr-namespace:Aevor.UI.Views"
        mc:Ignorable="d"
        Title="Aevor" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <!-- DataTemplates mapping ViewModel to View -->
        <DataTemplate DataType="{x:Type viewmodels:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:ProfilesViewModel}">
            <views:ProfilesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:TemplatesViewModel}">
            <views:TemplatesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:CloneWizardViewModel}">
            <views:CloneWizardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:BackupsViewModel}">
            <views:BackupsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:SecurityViewModel}">
            <views:SecurityView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>

        <!-- Sidebar Navigation Item Style -->
        <Style x:Key="SidebarNavItemStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="44" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontFamily" Value="{StaticResource DefaultFontFamily}" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderThickness="0"
                                SnapsToDevicePixels="true">
                            <Grid>
                                <!-- Left accent bar (active only) -->
                                <Border x:Name="accentBar" 
                                        HorizontalAlignment="Left" 
                                        Width="3" 
                                        Background="{StaticResource PrimaryBrush}" 
                                        Visibility="Collapsed" />
                                
                                <ContentPresenter x:Name="contentPresenter" 
                                                  Focusable="false" 
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}" 
                                                  Margin="{TemplateBinding Padding}" 
                                                  RecognizesAccessKey="True" 
                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource GhostHoverBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                            </Trigger>
                            <DataTrigger Binding="{Binding Path=Tag, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F3EFFE" />
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
                                <Setter TargetName="accentBar" Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- TopBar -->
        <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Background="White">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Left: Logo -->
                <TextBlock Grid.Column="0" Text="Aevor" Foreground="{StaticResource PrimaryBrush}" Style="{StaticResource H2TextBlockStyle}" VerticalAlignment="Center" Padding="24,0,0,0"/>

                <!-- Right: Placeholder Icons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,24,0">
                    <Border Width="32" Height="32" CornerRadius="16" Background="{StaticResource SurfaceBrush}" Margin="0,0,8,0">
                        <TextBlock Text="🔍" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <Border Width="32" Height="32" CornerRadius="16" Background="{StaticResource SurfaceBrush}">
                        <TextBlock Text="👤" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Body -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Top section: nav items -->
                    <StackPanel Grid.Row="0" Margin="0,16,0,0">
                        <!-- Dashboard -->
                        <Button Style="{StaticResource SidebarNavItemStyle}" Command="{Binding NavigateDashboardCommand}" Tag="{Binding IsDashboardActive}">
                            <DockPanel>
                                <Rectangle DockPanel.Dock="Left" Width="16" Height="16" Margin="0,0,12,0" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ContentPresenter}}" />
                                <TextBlock Text="Dashboard" VerticalAlignment="Center" Style="{StaticResource BodyTextBlockStyle}" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ContentPresenter}}"/>
                            </DockPanel>
                        </Button>

                        <!-- Profiles -->
                        <Button Style="{StaticResource SidebarNavItemStyle}" Command="{Binding NavigateProfilesCommand}" Tag="{Binding IsProfilesActive}">
                            <DockPanel>
                                <Rectangle DockPanel.Dock="Left" Width="16" Height="16" Margin="0,0,12,0" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ContentPresenter}}" />
                                <TextBlock Text="Profiles" VerticalAlignment="Center" Style="{StaticResource BodyTextBlockStyle}" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ContentPresenter}}"/>
                            </DockPanel>
                        </Button>

                        <!-- Templates -->
                        <Button Style="{StaticResource SidebarNavItemStyle}" Command="{Binding NavigateTemplatesCommand}" Tag="{Binding IsTemplatesActive}">
                            <DockPanel>
                                <Rectangle DockPanel.Dock="Left" Width="16" Height="16" Margin="0,0,12,0" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ContentPresenter}}" />
                                <TextBlock Text="Templates" VerticalAlignment="Center" Style="{StaticResource BodyTextBlockStyle}" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ContentPresenter}}"/>
                            </DockPanel>
                        </Button>

                        <!-- Clone -->
                        <Button Style="{StaticResource SidebarNavItemStyle}" Command="{Binding NavigateCloneCommand}" Tag="{Binding IsCloneActive}">
                            <DockPanel>
                                <Rectangle DockPanel.Dock="Left" Width="16" Height="16" Margin="0,0,12,0" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ContentPresenter}}" />
                                <TextBlock Text="Clone" VerticalAlignment="Center" Style="{StaticResource BodyTextBlockStyle}" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ContentPresenter}}"/>
                            </DockPanel>
                        </Button>

                        <!-- Backups -->
                        <Button Style="{StaticResource SidebarNavItemStyle}" Command="{Binding NavigateBackupsCommand}" Tag="{Binding IsBackupsActive}">
                            <DockPanel>
                                <Rectangle DockPanel.Dock="Left" Width="16" Height="16" Margin="0,0,12,0" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ContentPresenter}}" />
                                <TextBlock Text="Backups" VerticalAlignment="Center" Style="{StaticResource BodyTextBlockStyle}" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ContentPresenter}}"/>
                            </DockPanel>
                        </Button>

                        <!-- Security -->
                        <Button Style="{StaticResource SidebarNavItemStyle}" Command="{Binding NavigateSecurityCommand}" Tag="{Binding IsSecurityActive}">
                            <DockPanel>
                                <Rectangle DockPanel.Dock="Left" Width="16" Height="16" Margin="0,0,12,0" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ContentPresenter}}" />
                                <TextBlock Text="Security" VerticalAlignment="Center" Style="{StaticResource BodyTextBlockStyle}" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ContentPresenter}}"/>
                            </DockPanel>
                        </Button>
                    </StackPanel>

                    <!-- Bottom section: Settings -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,16">
                        <Button Style="{StaticResource SidebarNavItemStyle}" Command="{Binding NavigateSettingsCommand}" Tag="{Binding IsSettingsActive}">
                            <DockPanel>
                                <Rectangle DockPanel.Dock="Left" Width="16" Height="16" Margin="0,0,12,0" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ContentPresenter}}" />
                                <TextBlock Text="Settings" VerticalAlignment="Center" Style="{StaticResource BodyTextBlockStyle}" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ContentPresenter}}"/>
                            </DockPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content Area -->
            <Grid Grid.Column="1" Background="White">
                <ContentControl Content="{Binding CurrentView}" />
            </Grid>
        </Grid>
    </Grid>
</Window>
